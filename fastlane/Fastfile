default_platform(:ios)

platform :ios do
  desc "Increment the build number"
  lane :bump_build do
    increment_build_number(
      xcodeproj: "maps.earth.xcodeproj"
    )
    version = get_version_number(xcodeproj: "maps.earth.xcodeproj", target: "maps.earth")
    build   = get_build_number(xcodeproj: "maps.earth.xcodeproj")
    git_commit(
      path: "maps.earth.xcodeproj/project.pbxproj",
      message: "Bump build to v#{version} (#{build})"
    )
  end

  desc "Increment the minor version and reset build number to 0"
  lane :bump_version do
    increment_version_number(
      bump_type: "minor",
      xcodeproj: "maps.earth.xcodeproj"
    )
    increment_build_number(
      build_number: 0,
      xcodeproj: "maps.earth.xcodeproj"
    )
  end

  desc "Bump build, archive, and tag the app"
  lane :build_alpha do
    bump_build
    build_app(
      project: "maps.earth.xcodeproj",
      scheme: "maps.earth",
      configuration: "Release",
      output_directory: "build",
      output_name: "maps.earth.ipa",
      export_options: {
        method: "app-store",
        signingStyle: "automatic"
      }
    )
    tag_alpha
  end

  desc "Tag current version as alpha (e.g. v1.14.alpha2)"
  lane :tag_alpha do
    version = get_version_number(xcodeproj: "maps.earth.xcodeproj", target: "maps.earth")
    build   = get_build_number(xcodeproj: "maps.earth.xcodeproj")
    add_git_tag(tag: "v#{version}.alpha#{build}")
  end

  desc "Tag current version as beta (e.g. v1.14.beta2)"
  lane :tag_beta do
    version = get_version_number(xcodeproj: "maps.earth.xcodeproj", target: "maps.earth")
    build   = get_build_number(xcodeproj: "maps.earth.xcodeproj")
    add_git_tag(tag: "v#{version}.beta#{build}")
  end

  desc "Upload most recent build to App Store Connect"
  lane :upload do
    upload_to_app_store(
      ipa: "build/maps.earth.ipa",
      skip_metadata: true,
      skip_screenshots: true,
      precheck_include_in_app_purchases: false
    )
  end
end
