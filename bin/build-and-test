#!/bin/bash
set -euo pipefail

echo "🔧 Building framework dependencies..."

# Build the ferrostar iOS framework from its directory
pushd DevDependencies/ferrostar/common
./build-ios.sh
popd

pushd DevDependencies/headway
./bin/build-ios.sh
popd

echo "✅ Finished building framework dependencies!"

# Now run the tests
echo ""
./bin/test
